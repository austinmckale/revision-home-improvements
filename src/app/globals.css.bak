@import "tailwindcss";
@import url("https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&display=swap");

:root {
  --background: #fffaf2;
  --foreground: #1f2937;
  --surface: #ffffff;
  --surface-soft: #fdf6ee;
  --brand: #c7491f;
  --brand-dark: #9f3617;
  --accent: #194734;
  --muted: #6b7280;
  --border: #f1d8be;
}

@theme inline {
  --color-background: var(--background);
  --color-foreground: var(--foreground);
  --font-sans: "Trebuchet MS", "Segoe UI", sans-serif;
  --font-serif: "DM Serif Display", Georgia, "Times New Roman", serif;
  --font-mono: Consolas, "Courier New", monospace;
}

body {
  background: var(--background);
  color: var(--foreground);
  font-family: var(--font-sans);
}

a {
  color: inherit;
}

.surface {
  background: var(--surface);
  border: 1px solid var(--border);
}

.surface-soft {
  background: var(--surface-soft);
}

.heading-serif {
  font-family: var(--font-serif);
  font-weight: 400;
  letter-spacing: -0.01em;
}

.hero-band {
  background:
    radial-gradient(circle at 10% 20%, rgb(255 210 168 / 40%), transparent 35%),
    radial-gradient(circle at 90% 5%, rgb(25 71 52 / 6%), transparent 40%),
    linear-gradient(160deg, #fff8f0 0%, #fffcf8 40%, #f9fdfb 100%);
}
